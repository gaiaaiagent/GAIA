# Regen Registry Assistant - Production Environment
# Copy to /opt/projects/registry-eliza/.env and fill in values

# ============================================================================
# REQUIRED: AI Model Configuration
# ============================================================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model selection (optional - defaults to claude-sonnet-4-20250514)
# SMALL_MODEL=claude-sonnet-4-20250514
# MEDIUM_MODEL=claude-sonnet-4-20250514
# LARGE_MODEL=claude-sonnet-4-20250514

# ============================================================================
# REQUIRED: Database Configuration
# ============================================================================
# Using existing PostgreSQL with pgvector on the GAIA server
POSTGRES_URL=postgresql://postgres:your_postgres_password@127.0.0.1:5433/registry_eliza

# ============================================================================
# Server Configuration
# ============================================================================
NODE_ENV=production
SERVER_PORT=3001
SERVER_HOST=0.0.0.0

# Enable the web UI
ELIZA_UI_ENABLE=true

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=info

# ============================================================================
# Security (Optional)
# ============================================================================
# Uncomment to require authentication for API access
# ELIZA_SERVER_AUTH_TOKEN=your_secure_random_token

# ============================================================================
# MCP Server Configuration
# ============================================================================
# MCP servers are configured in .mcp.json file
# These environment variables can override specific settings

# Registry Review API base URL (if different from default)
# REGISTRY_REVIEW_API_URL=http://127.0.0.1:8080

# ============================================================================
# Optional: External Services
# ============================================================================
# Discord integration (if needed)
# DISCORD_APPLICATION_ID=
# DISCORD_API_TOKEN=

# Twitter integration (if needed)
# TWITTER_TARGET_USERS=
# TWITTER_DRY_RUN=true
