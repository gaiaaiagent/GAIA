# Use the existing Regen image as base
FROM ghcr.io/gaiaaiagent/gaia/regen:regen-latest

# Switch to root to install packages
USER root

WORKDIR /app

# Install the knowledge plugin
RUN cd packages/cli && bun add @elizaos/plugin-knowledge

# Ensure the knowledge directory exists
RUN mkdir -p /app/knowledge

# Switch back to non-root if needed
# USER node

EXPOSE 3000
EXPOSE 50000-50100/udp

# Use the same command as the original
CMD ["sh", "-c", "cd packages/cli && bun dist/index.js start --character /app/characters/regenai.character.json --character /app/characters/advocate.character.json --character /app/characters/governor.character.json --character /app/characters/narrative.character.json --character /app/characters/voiceofnature.character.json"]