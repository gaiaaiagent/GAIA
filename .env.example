####################################
#### Server Configuration ####
####################################

# Server Port
SERVER_PORT=3000

# Server Host (default: 0.0.0.0)
SERVER_HOST=

# Environment Mode (development/production - affects UI and security)
NODE_ENV=development

# Controls whether the web UI is available
# Set to "true" to force enable, "false" to force disable, or leave unset for automatic behavior
# Default: enabled in development, disabled in production
ELIZA_UI_ENABLE=

# Server authentication token for API access
# When set, all /api/* routes require X-API-KEY header with this value
ELIZA_SERVER_AUTH_TOKEN=

# Express Maximum Payload Size (default: 2mb)
EXPRESS_MAX_PAYLOAD=2mb

####################################
#### Database Configuration ####
####################################

# PostgreSQL Connection URL
POSTGRES_URL=

# PGLite Database Directory (or use memory:// for in-memory)
# Alternative to Postgres
PGLITE_DATA_DIR=

####################################
#### AI Model Provider APIs ####
####################################

# OpenAI API Key (required for default GPT-3.5-turbo)
OPENAI_API_KEY=

# Google Generative AI API Key
GOOGLE_GENERATIVE_AI_API_KEY=

# Anthropic Claude API Key (Embedding Provider required; will default to local embedding if not provided)
ANTHROPIC_API_KEY=

# OpenRouter API Key (Embedding Provider required; will default to local embedding if not provided)
OPENROUTER_API_KEY=

# Ollama API Endpoint (for local LLM hosting, supports embedding)
OLLAMA_API_ENDPOINT=

####################################
#### AI Model Configuration ####
####################################

# Text Provider (default: openai)
TEXT_PROVIDER=openai

# Chat Model (default: gpt-5-nano-2025-08-07)
TEXT_MODEL=gpt-5-nano-2025-08-07

# Embeddings Model (default: text-embedding-3-small)
TEXT_EMBEDDING_MODEL=text-embedding-3-small

# Alternative Model Options:
# - GPT-4: TEXT_MODEL=gpt-4o-mini (better quality, higher cost)
# - Claude: TEXT_MODEL=claude-3-haiku-20240307 TEXT_PROVIDER=anthropic
# - Gemini: TEXT_MODEL=gemini-1.5-flash TEXT_PROVIDER=google
# - Better Embeddings: TEXT_EMBEDDING_MODEL=text-embedding-3-large

####################################
#### Character & Content Loading ####
####################################

# Remote Character URLs (comma-separated)
REMOTE_CHARACTER_URLS=


####################################
#### Development & Build Control ####
####################################

# Non-interactive CLI Mode (true/false)
ELIZA_NONINTERACTIVE=

####################################
#### Plugin Control ####
####################################
# Note: for all available / required configuration for specific plugins
# Check agentConfig property on their package.json


# Skip loading the bootstrap plugin (any value)
# Do not change if you are not customizing bootstrap with another plugin
IGNORE_BOOTSTRAP=

####################################
#### Character-Specific Settings ####
####################################

# ElizaOS automatically loads environment variables with this pattern:
# CHARACTER.{CHARACTER_NAME}.{SETTING_KEY}
#
# The CHARACTER_NAME should match the "name" field in your character.json file,
# converted to UPPERCASE with spaces replaced by underscores.
#
# Examples for a character named "Governor":
# CHARACTER.GOVERNOR.TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# CHARACTER.GOVERNOR.OPENAI_API_KEY=your-openai-key
# CHARACTER.GOVERNOR.CUSTOM_SETTING=some-value
#
# Examples for a character named "My Agent":
# CHARACTER.MY_AGENT.TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# CHARACTER.MY_AGENT.DISCORD_BOT_TOKEN=your-discord-token

####################################
#### Telegram Plugin Configuration ####
####################################

# Telegram Bot Tokens - Use CHARACTER-specific pattern above for production
# Example for Governor character:
# CHARACTER.GOVERNOR.TELEGRAM_BOT_TOKEN=

# Telegram Mention-Only Mode (NEW FEATURE)
# Only respond when directly mentioned, in DMs, or random responses
# CHARACTER.GOVERNOR.TELEGRAM_ONLY_RESPOND_WHEN_MENTIONED=true
# CHARACTER.GOVERNOR.TELEGRAM_RANDOM_RESPONSE_RATE=0.01

# Benefits of mention-only mode:
# - Faster response decisions (no LLM shouldRespond calls)
# - Lower API costs (fewer LLM requests)
# - More reliable mention detection (programmatic vs LLM-based)
# - Configurable per agent

# ⚠️ CRITICAL DEPLOYMENT NOTE:
# The CHARACTER.* environment variable pattern works differently based on database:
# - PGLite: Variables accessible during plugin initialization ✅
# - PostgreSQL: Variables NOT accessible during plugin initialization ❌
#
# For PostgreSQL deployments, use manual environment injection in startup scripts:
# CHARACTER.GOVERNOR.TELEGRAM_ONLY_RESPOND_WHEN_MENTIONED=true \
# CHARACTER.GOVERNOR.TELEGRAM_RANDOM_RESPONSE_RATE=0.01 \
# bun packages/cli/dist/index.js start --character characters/governor.character.json
#
# This is due to ElizaOS initialization order differences between database backends.

# Global Telegram settings (optional)
TELEGRAM_API_ROOT=
TELEGRAM_ALLOWED_CHATS=
TELEGRAM_TEST_CHAT_ID=

####################################
#### Discord Plugin Configuration ####
####################################

# Discord Application ID
DISCORD_APPLICATION_ID=

# Discord API Token - Use CHARACTER-specific pattern for production
# Example: CHARACTER.GOVERNOR.DISCORD_API_TOKEN=
DISCORD_API_TOKEN=
