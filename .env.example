# RegenAI Environment Configuration
# Copy this file to .env and fill in your actual values

# Database Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=your_database_name
POSTGRES_USER=your_database_user
POSTGRES_PASSWORD=your_database_password

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Configuration (optional)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram Bot Tokens
# Each agent needs its own bot token from @BotFather
TELEGRAM_BOT_TOKEN_REGENAI=your_regenai_bot_token_here
CHARACTER.RegenAI.TELEGRAM_BOT_TOKEN=your_regenai_bot_token_here

TELEGRAM_BOT_TOKEN_ADVOCATE=your_advocate_bot_token_here
CHARACTER.Advocate.TELEGRAM_BOT_TOKEN=your_advocate_bot_token_here

TELEGRAM_BOT_TOKEN_GOVERNOR=your_governor_bot_token_here
CHARACTER.Governor.TELEGRAM_BOT_TOKEN=your_governor_bot_token_here

TELEGRAM_BOT_TOKEN_NARRATIVE=your_narrative_bot_token_here
CHARACTER.Narrative.TELEGRAM_BOT_TOKEN=your_narrative_bot_token_here

TELEGRAM_BOT_TOKEN_VOICEOFNATURE=your_voiceofnature_bot_token_here
CHARACTER.VoiceOfNature.TELEGRAM_BOT_TOKEN=your_voiceofnature_bot_token_here

# ElizaOS Configuration
ELIZAOS_PORT=3000
ELIZAOS_LOG_LEVEL=info

# Grant System Configuration
GRANT_API_PORT=3007
DIRECT_LLM_PORT=3006

# KOI System Configuration
KOI_API_PORT=8001
FUSEKI_ADMIN_PASSWORD=admin

# Node Configuration
NODE_ENV=production

# Security
JWT_SECRET=your_jwt_secret_here
SESSION_SECRET=your_session_secret_here

# Optional: Ollama Configuration (for local models)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama2

# Optional: Model Router Configuration
# MODEL_ROUTER_ENDPOINT=http://localhost:51352
# MODEL_ROUTER_API_KEY=your_model_router_key_here

# Optional: Small Model Configuration
# SMALL_MODEL_PROVIDER=openai
# SMALL_OPENAI_API_KEY=your_small_model_api_key_here
