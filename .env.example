# RegenAI Environment Configuration Example
# Copy this file to .env and fill in your actual values

# Required - OpenAI API Key for embeddings
OPENAI_API_KEY=your_openai_api_key_here

# Required - PostgreSQL Database
POSTGRES_URL=postgresql://username:password@localhost:5432/database_name

# Optional - Anthropic API (for better conversational AI)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_SMALL_MODEL=claude-3-5-haiku-latest
ANTHROPIC_LARGE_MODEL=claude-3-5-sonnet-latest

# Optional - Ollama Configuration (for local models)
OLLAMA_API_ENDPOINT=http://localhost:11434/api
OLLAMA_SMALL_MODEL=llama3.2:3b
OLLAMA_MEDIUM_MODEL=llama3.1
OLLAMA_LARGE_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Model Configuration
TEXT_PROVIDER=anthropic  # or openai, ollama
TEXT_MODEL=claude-3-5-haiku-latest
TEXT_EMBEDDING_MODEL=nomic-embed-text

# Knowledge Configuration
LOAD_DOCS_ON_STARTUP=true
CTX_KNOWLEDGE_ENABLED=false

# Regen Network Endpoints (for MCP)
REGEN_RPC_ENDPOINT=https://regen-rpc.polkachu.com
REGEN_REST_ENDPOINT=https://regen-rest.publicnode.com

# Security
SECRET_SALT=change_this_to_a_secure_random_string

# Logging
LOG_LEVEL=info

# Server Configuration
ELIZA_SERVER_AUTH_TOKEN=optional_auth_token_for_server