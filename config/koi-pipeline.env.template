# KOI Pipeline Environment Configuration Template
# Copy this file to koi-pipeline.env and update with your settings

# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL connection string for Eliza database
POSTGRES_URL=postgresql://postgres:postgres@localhost:5433/eliza

# Individual PostgreSQL settings
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=eliza
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# =============================================================================
# KOI Coordinator Configuration
# =============================================================================

# Port for the KOI Coordinator service
KOI_COORDINATOR_PORT=8200

# Host binding (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
KOI_COORDINATOR_HOST=0.0.0.0

# Node name for the coordinator
KOI_NODE_NAME=coordinator-main

# =============================================================================
# KOI Event Bridge Configuration
# =============================================================================

# Port for the Event Bridge service
KOI_EVENT_BRIDGE_PORT=8100

# Host binding
KOI_EVENT_BRIDGE_HOST=0.0.0.0

# Processing batch size
KOI_BATCH_SIZE=10

# Processing timeout (seconds)
KOI_PROCESSING_TIMEOUT=30

# =============================================================================
# BGE Embedding Server Configuration
# =============================================================================

# Port for the BGE embedding server
BGE_SERVER_PORT=8888

# Host binding
BGE_SERVER_HOST=0.0.0.0

# Model configuration (if using real BGE)
# BGE_MODEL_NAME=BAAI/bge-large-en-v1.5
# BGE_MODEL_PATH=/path/to/model

# Embedding dimensions
BGE_EMBEDDING_DIM=1024

# =============================================================================
# Website Sensor Configuration
# =============================================================================

# Check interval in seconds (1800 = 30 minutes)
WEBSITE_CHECK_INTERVAL=1800

# Maximum crawl depth for each website
WEBSITE_MAX_DEPTH=3

# User agent string for web requests
WEBSITE_USER_AGENT="KOI-Sensor/1.0 (+https://github.com/gaiaaiagent/koi-sensors)"

# Request timeout in seconds
WEBSITE_REQUEST_TIMEOUT=30

# =============================================================================
# Agent Configuration
# =============================================================================

# Default agent ID for content assignment
DEFAULT_AGENT_ID=8e1e4498-b3c8-0fae-ad1f-e90d1c1a4331

# Agent room ID (optional)
# AGENT_ROOM_ID=

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log directory
LOG_DIR=/var/log/koi

# Log rotation settings
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5

# =============================================================================
# Performance Tuning
# =============================================================================

# Maximum concurrent processing tasks
MAX_CONCURRENT_TASKS=5

# Database connection pool size
DB_POOL_SIZE=10

# Cache settings
CACHE_ENABLED=true
CACHE_TTL=3600  # 1 hour

# =============================================================================
# Security Settings
# =============================================================================

# API authentication (if implementing)
# API_KEY=your-secure-api-key-here

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# Optional Services
# =============================================================================

# Apache Jena Fuseki (if using)
# FUSEKI_URL=http://localhost:3030
# FUSEKI_DATASET=koi
# FUSEKI_USERNAME=admin
# FUSEKI_PASSWORD=admin

# MCP Server (if using)
# MCP_SERVER_URL=http://localhost:3000

# =============================================================================
# Development/Debug Settings
# =============================================================================

# Enable debug mode (more verbose logging)
DEBUG=false

# Enable test mode (uses mock data)
TEST_MODE=false

# Pretty print JSON responses
PRETTY_JSON=true